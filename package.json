    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/azure-sdk": "0.1.0",
    "@grafana/data": "13.1.1",
    "@grafana/i18n": "13.1.1",
    "@grafana/plugin-ui": "0.17.3",
    "@grafana/prometheus": "13.1.8",
    "@grafana/runtime": "13.1.1",
    "@grafana/schema": "13.1.1",
    "@grafana/ui": "13.1.1",
    "lodash": "4.18.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.15.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "webpack-merge": "6.0.1"
  },
  "overrides": {
    "string-width": "4.2.3",
    "wrap-ansi": "7.0.0",
    "dompurify": "3.4.9",
    "immutable@5": "5.1.5",
    "js-cookie": "3.0.7",
