{
  "name": "grafana-azureprometheus-datasource",
  "version": "1.0.3",
  "description": "A plugin for Azure Monitor Managed Service for Prometheus",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "e2e": "playwright test",
    "e2e:ui": "npx playwright test --ui",
    "i18n-extract": "i18next --config src/locales/i18next-parser.config.cjs",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "server:configured": "GRAFANA_VERSION=11.5.0 GRAFANA_IMAGE=grafana-enterprise docker compose up -d",
    "sign": "sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "server": "docker compose up --build"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@eslint/compat": "2.0.5",
    "@grafana/e2e-selectors": "13.1.1",
    "@grafana/eslint-config": "10.0.0",
    "@grafana/plugin-e2e": "3.10.0",
    "@grafana/sign-plugin": "3.3.3",
    "@grafana/tsconfig": "2.2.0",
    "@playwright/test": "1.59.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.30",
    "@swc/jest": "0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/eslint": "9.6.1",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.7.1",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "copy-webpack-plugin": "14.0.0",
    "cspell": "9.8.0",
    "css-loader": "7.1.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "5.0.3",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "11.1.0",
    "i18next-parser": "9.4.0",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "prettier": "3.8.3",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "semver": "7.7.4",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.4.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.2",
    "webpack": "5.105.4",
    "webpack-cli": "7.0.2",
